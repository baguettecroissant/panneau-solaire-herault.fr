---
import config from '../data/config.json';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Col 1 -->
      <div class="footer-col">
        <a href="/" class="footer-brand">
          <span class="sun-icon">🔆</span>
          <span class="brand-name">{config.brandName}</span>
        </a>
        <p class="footer-desc">
          Spécialiste de l'installation de panneaux solaires photovoltaïques en autoconsommation dans l'Hérault (34). Bénéficiez des 2 700 heures de soleil annuel de Montpellier, Béziers, Sète et leurs environs.
        </p>
        <div class="footer-badge">
          <span>🛡️ Pros Certifiés QualiPV RGE 34</span>
        </div>
      </div>

      <!-- Col 2 -->
      <div class="footer-col">
        <h3 class="footer-title">Navigation</h3>
        <ul class="footer-links">
          <li><a href="/">Accueil</a></li>
          <li><a href="/devis">Demande de Devis Gratuit</a></li>
          <li><a href="/tarifs">Tarifs & Prix 2026</a></li>
          <li><a href="/guide-autoconsommation-herault">Guide Autoconsommation Hérault</a></li>
          <li><a href="/aides-panneau-solaire-34">Aides Financières Solaire 34</a></li>
          <li><a href="/guides">Tous les Guides Solaires</a></li>
          <li><a href="/communes">Toutes les Communes du 34</a></li>
        </ul>
      </div>

      <!-- Col 3 -->
      <div class="footer-col">
        <h3 class="footer-title">Principales Villes (34)</h3>
        <div class="communes-pills">
          <a href="/panneau-solaire-montpellier">Montpellier</a>
          <a href="/panneau-solaire-beziers">Béziers</a>
          <a href="/panneau-solaire-sete">Sète</a>
          <a href="/panneau-solaire-agde">Agde</a>
          <a href="/panneau-solaire-lunel">Lunel</a>
          <a href="/panneau-solaire-frontignan">Frontignan</a>
          <a href="/panneau-solaire-castelnau-le-lez">Castelnau-le-Lez</a>
          <a href="/panneau-solaire-mauguio">Mauguio</a>
          <a href="/panneau-solaire-lattes">Lattes</a>
          <a href="/panneau-solaire-perols">Pérols</a>
          <a href="/panneau-solaire-meze">Mèze</a>
          <a href="/panneau-solaire-saint-gely-du-fesc">Saint-Gély-du-Fesc</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 {config.brandName}. Tous droits réservés. Service indépendant d'installation solaire dans le département de l'Hérault (34).</p>
      <div class="legal-links">
        <a href="/mentions-legales">Mentions Légales</a>
        <span>•</span>
        <a href="/politique-confidentialite">Politique de Confidentialité</a>
      </div>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background-color: #020617; /* slate-950 */
  color: #94A3B8;
  padding: 4rem 0 2rem;
  margin-top: auto;
  border-top: 1px solid #1E293B;
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

@media (max-width: 900px) {
  .footer-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

.footer-brand {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  margin-bottom: 1rem;
}

.sun-icon { font-size: 1.5rem; }

.brand-name {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 700;
  color: #FFFFFF;
}

.footer-desc {
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 1.25rem;
}

.footer-badge {
  display: inline-block;
  background: rgba(30, 64, 175, 0.3);
  border: 1px solid rgba(59, 130, 246, 0.4);
  padding: 0.4rem 0.8rem;
  border-radius: var(--radius-sm);
  color: #60A5FA;
  font-weight: 600;
  font-size: 0.85rem;
}

.footer-title {
  color: #FFFFFF;
  font-size: 1.1rem;
  margin-bottom: 1.2rem;
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.footer-links a {
  color: #94A3B8;
  transition: color 0.2s;
  font-size: 0.95rem;
}

.footer-links a:hover {
  color: #FACC15;
}

.communes-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.communes-pills a {
  background: #0F172A;
  border: 1px solid #1E293B;
  color: #93C5FD;
  padding: 0.3rem 0.65rem;
  border-radius: var(--radius-pill);
  font-size: 0.8rem;
  transition: all 0.2s;
}

.communes-pills a:hover {
  background: var(--primary);
  color: #FFFFFF;
  border-color: var(--accent);
}

.footer-bottom {
  border-top: 1px solid #1E293B;
  padding-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.875rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.legal-links {
  display: flex;
  gap: 0.75rem;
  align-items: center;
}

.legal-links a {
  color: #94A3B8;
}

.legal-links a:hover {
  color: #FFFFFF;
}
</style>
