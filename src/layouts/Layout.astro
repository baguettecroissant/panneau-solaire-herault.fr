---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schemaJson?: object;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  schemaJson
} = Astro.props;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "SolarEnergyContractor",
  "name": "Panneau Solaire Hérault (34)",
  "url": "https://panneau-solaire-herault.fr",
  "logo": "https://panneau-solaire-herault.fr/images/hero-panneau-solaire-herault.png",
  "description": description,
  "telephone": "04 67 00 00 00",
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Hérault",
    "identifier": "34"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Montpellier",
    "addressRegion": "Occitanie",
    "postalCode": "34000",
    "addressCountry": "FR"
  },
  "priceRange": "€€€"
};

const schema = schemaJson || defaultSchema;
---

<!usr/bin/env html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- OpenGraph -->
  <meta property="og:site_name" content="Panneau Solaire Hérault" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://panneau-solaire-herault.fr/images/hero-panneau-solaire-herault.png" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://panneau-solaire-herault.fr/images/hero-panneau-solaire-herault.png" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
