---
import Layout from '../../layouts/Layout.astro';
import StepsForm from '../../components/StepsForm.astro';
import { guides, type Article } from '../../data/guides';

export async function getStaticPaths() {
  return guides.map(g => ({
    params: { slug: g.slug },
    props: { guide: g }
  }));
}

interface Props {
  guide: Article;
}

const { guide } = Astro.props;
---

<Layout
  title={`${guide.title} — Panneau Solaire Hérault`}
  description={guide.excerpt}
>
  <div class="page-banner bg-light">
    <div class="container text-center">
      <span class="badge-gold">📖 GUIDE SOLAIRE 34</span>
      <h1 class="page-title">{guide.title}</h1>
      <div class="article-meta-row">
        <span>Publié le {guide.date}</span>
        <span>•</span>
        <span>⏱️ Temps de lecture : {guide.readTime}</span>
      </div>
    </div>
  </div>

  <section class="section-padding container">
    <div class="article-layout">
      <img src={guide.image} alt={guide.title} class="article-hero-img" width="1000" height="500" />
      <div class="article-body" set:html={guide.content} />
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container">
      <StepsForm />
    </div>
  </section>
</Layout>

<style>
.page-banner {
  padding: 3.5rem 0 2.5rem;
  border-bottom: 1px solid var(--border-color);
}

.page-title {
  font-size: 2.1rem;
  margin-top: 0.6rem;
  margin-bottom: 0.75rem;
  color: var(--primary-dark);
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
}

.article-meta-row {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-muted);
}

.article-layout {
  max-width: 850px;
  margin: 0 auto;
}

.article-hero-img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  margin-bottom: 2rem;
  box-shadow: var(--shadow-md);
}

.article-body h2 {
  font-size: 1.75rem;
  color: var(--primary-dark);
  margin-top: 2rem;
  margin-bottom: 1rem;
}

.article-body h3 {
  font-size: 1.3rem;
  color: var(--text);
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
}

.article-body p {
  font-size: 1.1rem;
  line-height: 1.7;
  color: #334155;
  margin-bottom: 1.25rem;
}
</style>
