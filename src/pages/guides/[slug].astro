---
import Layout from '../../layouts/Layout.astro';
import StepsForm from '../../components/StepsForm.astro';
import { guides, type Article } from '../../data/guides';

export async function getStaticPaths() {
  return guides.map(g => ({
    params: { slug: g.slug },
    props: { guide: g }
  }));
}

interface Props {
  guide: Article;
}

const { guide } = Astro.props;

// Filter out current guide for sidebar
const otherGuides = guides.filter(g => g.slug !== guide.slug).slice(0, 4);
---

<Layout
  title={`${guide.title} — Panneau Solaire Hérault`}
  description={guide.excerpt}
>
  <div class="page-banner bg-light">
    <div class="container">
      <div class="banner-inner">
        <a href="/guides" class="back-link">← Retour aux guides</a>
        <br />
        <span class="badge-gold">📖 GUIDE EXPERT 2026</span>
        <h1 class="page-title">{guide.title}</h1>
        <div class="article-meta-row">
          <span>📅 Mis à jour le {guide.date}</span>
          <span>•</span>
          <span>⏱️ Temps de lecture : {guide.readTime}</span>
        </div>
      </div>
    </div>
  </div>

  <section class="section-padding container">
    <div class="article-layout-grid">
      <!-- Left Main Column -->
      <article class="article-main">
        <img src={guide.image} alt={guide.title} class="article-hero-img" width="1000" height="500" />
        
        <div class="article-body" set:html={guide.content} />
      </article>

      <!-- Right Sidebar Column -->
      <aside class="article-sidebar">
        <!-- CTA Widget -->
        <div class="sidebar-widget cta-widget">
          <h3 class="widget-title">Simuler mon gain</h3>
          <p>Obtenez une étude de rendement gratuite en 2 minutes par des artisans QualiPV RGE de l'Hérault.</p>
          <a href="#devis" class="btn-primary" style="width: 100%; box-shadow: none;">Estimer ma production</a>
        </div>

        <!-- Key Facts -->
        <div class="sidebar-widget">
          <h3 class="widget-title">Chiffres clés du 34</h3>
          <ul class="widget-links" style="display: flex; flex-direction: column; gap: 0.85rem;">
            <li style="font-size: 0.9rem; color: var(--text); list-style: none;">☀️ <strong>2 700 heures</strong> d'ensoleillement annuel</li>
            <li style="font-size: 0.9rem; color: var(--text); list-style: none;">⚡ <strong>1 350 kWh / kWc</strong> de rendement moyen</li>
            <li style="font-size: 0.9rem; color: var(--text); list-style: none;">💶 <strong>1 680 €</strong> de Prime autoconsommation (6 kWc)</li>
            <li style="font-size: 0.9rem; color: var(--text); list-style: none;">🛡️ <strong>QualiPV RGE</strong> : label d'installation requis</li>
          </ul>
        </div>

        <!-- Other Guides Widget -->
        <div class="sidebar-widget">
          <h3 class="widget-title">Autres guides utiles</h3>
          <ul class="widget-links">
            {otherGuides.map(g => (
              <li>
                <a href={`/guides/${g.slug}`}>{g.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-padding bg-light" id="estimation-section">
    <div class="container">
      <StepsForm />
    </div>
  </section>
</Layout>

<style>
.page-banner {
  padding: 3.5rem 0 2.5rem;
  border-bottom: 1px solid var(--border-color);
  background: linear-gradient(to bottom, var(--primary-light), #FFFFFF);
}

.banner-inner {
  max-width: 900px;
  margin: 0 auto;
}

.back-link {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--primary);
  display: inline-block;
  margin-bottom: 1rem;
}

.page-title {
  font-size: 2.25rem;
  margin-top: 0.5rem;
  margin-bottom: 0.75rem;
  color: var(--primary-dark);
  line-height: 1.2;
}

.article-meta-row {
  display: flex;
  gap: 1rem;
  font-size: 0.9rem;
  color: var(--text-muted);
  font-weight: 500;
}

.article-main {
  background: #FFFFFF;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  box-shadow: var(--shadow-sm);
}

.article-hero-img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  margin-bottom: 2.5rem;
  display: block;
}

@media (max-width: 600px) {
  .article-main {
    padding: 1.25rem;
  }
  .page-title {
    font-size: 1.6rem;
  }
}
</style>
